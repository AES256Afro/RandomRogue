{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://random-rogue.com/schemas/rr.chronicle.v1.json",
  "title": "Random Rogue Chronicle event envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "event_id",
    "event_type",
    "source",
    "world_key",
    "occurred_at",
    "subject",
    "payload",
    "visibility"
  ],
  "properties": {
    "schema": { "const": "rr.chronicle.v1" },
    "event_id": {
      "type": "string",
      "pattern": "^(wide|mud):evt:[A-Za-z0-9:_-]{8,120}$"
    },
    "event_type": {
      "enum": [
        "wide_world.death",
        "wide_world.deed",
        "wide_world.ending",
        "wide_world.institution_changed",
        "wide_world.artifact_legacy",
        "wide_world.region_changed",
        "mud.death",
        "mud.deed",
        "mud.institution_changed",
        "mud.artifact_changed"
      ]
    },
    "source": { "enum": ["wide_world", "mud"] },
    "world_key": {
      "type": "string",
      "pattern": "^(daily|weekly|persistent):[A-Za-z0-9:_-]{1,80}$"
    },
    "occurred_at": { "type": "string", "format": "date-time" },
    "subject": { "$ref": "#/$defs/subject" },
    "place": { "$ref": "#/$defs/place" },
    "tags": {
      "type": "array",
      "maxItems": 12,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]{0,31}$" }
    },
    "effects": {
      "type": "object",
      "maxProperties": 16,
      "propertyNames": { "pattern": "^[a-z][a-z0-9_]{0,31}$" },
      "additionalProperties": { "type": "integer", "minimum": -10, "maximum": 10 }
    },
    "payload": {
      "type": "object",
      "maxProperties": 32
    },
    "visibility": { "enum": ["public", "private", "moderated"] }
  },
  "allOf": [
    {
      "if": { "properties": { "event_type": { "const": "wide_world.death" } } },
      "then": {
        "properties": {
          "subject": { "allOf": [{ "$ref": "#/$defs/subject" }, { "properties": { "kind": { "const": "character" } } }] },
          "payload": { "$ref": "#/$defs/deathPayload" }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "enum": ["wide_world.deed", "wide_world.ending"] } } },
      "then": {
        "properties": {
          "subject": { "allOf": [{ "$ref": "#/$defs/subject" }, { "properties": { "kind": { "const": "character" } } }] },
          "payload": { "$ref": "#/$defs/rumorPayload" }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "const": "wide_world.institution_changed" } } },
      "then": {
        "properties": {
          "subject": { "allOf": [{ "$ref": "#/$defs/subject" }, { "properties": { "kind": { "const": "institution" } } }] },
          "payload": { "$ref": "#/$defs/institutionPayload" }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "const": "wide_world.region_changed" } } },
      "then": {
        "properties": {
          "subject": { "allOf": [{ "$ref": "#/$defs/subject" }, { "properties": { "kind": { "const": "region" } } }] },
          "payload": { "$ref": "#/$defs/regionPayload" }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "const": "wide_world.artifact_legacy" } } },
      "then": {
        "properties": {
          "subject": { "allOf": [{ "$ref": "#/$defs/subject" }, { "properties": { "kind": { "const": "artifact" } } }] },
          "payload": { "$ref": "#/$defs/artifactPayload" }
        }
      }
    }
  ],
  "$defs": {
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id", "name"],
      "properties": {
        "kind": { "enum": ["character", "institution", "artifact", "region", "site"] },
        "id": { "type": "string", "pattern": "^(wide|mud):[A-Za-z0-9:_-]{3,120}$" },
        "name": { "type": "string", "minLength": 2, "maxLength": 80 }
      }
    },
    "place": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "region_id": { "type": "string", "pattern": "^(wide|mud):region:[A-Za-z0-9:_-]{1,100}$" },
        "site_id": { "type": "string", "pattern": "^(wide|mud):site:[A-Za-z0-9:_-]{1,100}$" },
        "name": { "type": "string", "maxLength": 80 }
      }
    },
    "deathPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "meaning": { "type": "string", "maxLength": 60 },
        "epitaph": { "type": "string", "maxLength": 160 },
        "cause": { "type": "string", "maxLength": 160 },
        "days": { "type": "integer", "minimum": 0, "maximum": 9999 }
      }
    },
    "rumorPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "title": { "type": "string", "minLength": 2, "maxLength": 80 },
        "text": { "type": "string", "minLength": 2, "maxLength": 280 }
      }
    },
    "institutionPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["institution_id", "name", "summary"],
      "properties": {
        "institution_id": { "type": "string", "pattern": "^wide:institution:[A-Za-z0-9:_-]{1,100}$" },
        "name": { "type": "string", "minLength": 2, "maxLength": 80 },
        "summary": { "type": "string", "minLength": 2, "maxLength": 280 }
      }
    },
    "regionPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["region_id", "name", "notice"],
      "properties": {
        "region_id": { "type": "string", "pattern": "^wide:region:[A-Za-z0-9:_-]{1,100}$" },
        "name": { "type": "string", "minLength": 2, "maxLength": 80 },
        "notice": { "type": "string", "minLength": 2, "maxLength": 280 }
      }
    },
    "artifactPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "name", "description", "provenance"],
      "properties": {
        "artifact_id": { "type": "string", "pattern": "^wide:artifact:[A-Za-z0-9:_-]{1,100}$" },
        "name": { "type": "string", "minLength": 2, "maxLength": 80 },
        "description": { "type": "string", "minLength": 2, "maxLength": 280 },
        "provenance": { "type": "string", "minLength": 2, "maxLength": 280 }
      }
    }
  }
}
